---
// MainNav.astro
---

<nav class="main-nav box-shadow">
  <ul>
    <li><a href="/#hero">Home</a></li>
    <li><a href="/#bikes">Bikes</a></li>
    <li><a href="/#about">About</a></li>
  </ul>
</nav>

<style lang="scss">
  nav {
    width: fit-content;
    padding: 0 0.5em;
    background: var(--white);
    // position: relative;
    // align-self: center;
    justify-self: center;
    border-radius: 8px;
    z-index: 2;
    // grid-column: 1;
    // grid-row: 1;
    &::after {
      content: "";
      border-radius: 8px;
      background-color: var(--teal);

      height: 4px;
      // inset: auto 0 0;
      position: absolute;
      opacity: .5;
    }
    &:has(a:hover) {
      &::after {
        /*       background-color:red; */
      }
    }

    > ul {
      padding: 0;
      margin: 0;
      list-style: none;
      display: flex;
      // flex-direction: column;
      // gap: 0.5em;
      li{
        padding: .25em;
      }
    }

    a {
      display: block;
      padding: 0.5em;
      text-decoration: none;
      color: var(--black);
      position: relative;
      z-index: 2;
      transition: color 150ms;
       transition-delay: 250ms;

    }

  }
  @supports (anchor-name: --nav) {
    nav {
      anchor-name: --nav;
      &::after {
        position-anchor: --nav;
        left: calc(anchor(left) + 12px);
        bottom: calc(anchor(bottom) + 7px);
        right: calc(anchor(right) + 12px);
        transition:  250ms;
       opacity:.5;
      }
      a:hover {
        anchor-name: --nav;
      }
      &:has(a:hover){
        &::after{
          opacity: 1;
        }
      }
    }
  }
</style>
